{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(curl * | sh*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(npm publish*)",
      "Bash(vercel env *)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ]
  }
}